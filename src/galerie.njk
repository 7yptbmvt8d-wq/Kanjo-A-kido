---
layout: base.njk
active: galerie
permalink: /galerie.html
title_tag: "Galerie — Kanjo Aïkido Isulanu"
description: "Images de la pratique au dojo Kanjo Aïkido Isulanu : tatamis, armes, stages et instants partagés."
---
{% set p = pages.galerie %}
<!-- ===== HEADER ===== -->
<section class="section section--tight">
  <div class="section__inner" style="text-align:center;">
    <div class="eyebrow">{{ p.eyebrow }}</div>
    <h1 class="hero__title" style="font-size:clamp(34px,5vw,58px);">{{ p.title }}</h1>
    <p class="section-lead" style="max-width:620px; margin:0 auto;">{{ p.lead }}</p>
  </div>
</section>

<!-- ===== MOSAÏQUE ===== -->
<section class="section" style="padding-top:20px;">
  <div class="section__inner" style="padding-top:30px;">
    <div class="gallery">
      {%- if galerie.photos and galerie.photos.length %}
        {%- for photo in galerie.photos %}
        <div class="gallery__item">
          <img src="{{ photo.image }}" alt="{{ photo.alt }}" style="width:100%; height:100%; object-fit:cover;">
        </div>
        {%- endfor %}
      {%- else %}
        {%- for i in range(0, 9) %}
        <div class="gallery__item placeholder-media">[ photo ]</div>
        {%- endfor %}
      {%- endif %}
    </div>
    {%- if not (galerie.photos and galerie.photos.length) %}
    <p class="note-italic">{{ p.note }}</p>
    {%- endif %}
  </div>
</section>
